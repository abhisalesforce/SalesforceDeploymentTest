# Source Environment (dev/sandbox)
SOURCE_ORG=your-source-username@example.com

# Destination Environment (staging/production)
DESTINATION_ORG=your-dest-username@example.com

# Optional: Metadata directory for local deploy.sh usage
METADATA_DIR=path/to/metadata

# ---------------------------------------------------------------
# GitHub Actions secrets required for JWT authentication
# (set these under Settings > Secrets and variables > Actions)
# ---------------------------------------------------------------
#
# SOURCE_JWT_KEY   - RSA private key (PEM format) for the source org Connected App.
#                    Must begin with -----BEGIN RSA PRIVATE KEY----- or
#                    -----BEGIN PRIVATE KEY----- and include all newlines.
#                    Generate with:
#                      openssl genrsa -out server.key 2048
#                      openssl req -new -x509 -key server.key -out server.crt -days 365
#                    Upload server.crt to the Connected App in Salesforce.
#                    Paste the full contents of server.key as the secret value.
#
# SOURCE_CLIENT_ID - OAuth Consumer Key of the Connected App in the source org.
#
# SOURCE_USERNAME  - Salesforce username authorised by the Connected App.
#
# SOURCE_INSTANCE_URL - (optional) Salesforce login URL.
#                       Defaults to https://login.salesforce.com (production).
#                       Use https://test.salesforce.com for sandbox orgs.
#
# DEST_JWT_KEY, DEST_CLIENT_ID, DEST_USERNAME, DEST_INSTANCE_URL
#                  - Same as above but for the destination org.
