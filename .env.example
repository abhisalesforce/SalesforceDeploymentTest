# Source Environment (dev/sandbox)
SOURCE_ORG_ALIAS=source-org
SOURCE_USERNAME=your-source-username@example.com

# Destination Environment (staging/production)
DEST_ORG_ALIAS=dest-org
DEST_USERNAME=your-dest-username@example.com

# Deployment Options
DEPLOY_CHECK_ONLY=false
DEPLOY_TEST_LEVEL=RunLocalTests